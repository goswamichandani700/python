43. Show product lines where total quantity sold is greater than 10,000 (use multiple joins + GROUP BY + HAVING).


SELECT pl.productLine, SUM(od.quantityOrdered) AS total_quantity_sold FROM productlines pl INNER JOIN products p ON pl.productLine = p.productLine INNER JOIN orderdetails od ON p.productCode = od.productCode GROUP BY pl.productLine HAVING SUM(od.quantityOrdered) > 10000;

44. List the top 5 customers by total order value in 2004.

SELECT  c.customerNumber, c.customerName, SUM(od.quantityOrdered * od.priceEach) AS total_order_value FROM customers c INNER JOIN orders o ON c.customerNumber = o.customerNumber INNER JOIN orderdetails od ON o.orderNumber = od.orderNumber WHERE YEAR(o.orderDate) = 2004 GROUP BY c.customerNumber, c.customerName ORDER BY total_order_value DESC LIMIT 5;

45. Find employees who have no customers assigned and work in offices with more than 3 employees.

SELECT  e.employeeNumber,  e.firstName,  e.lastName,  e.officeCode FROM  employees e WHERE 
    -- Condition 1: Employee has no customers assigned
    e.employeeNumber NOT IN (
        SELECT DISTINCT salesRepEmployeeNumber 
        FROM customers 
        WHERE salesRepEmployeeNumber IS NOT NULL
    )
    -- Condition 2: Works in an office with more than 3 employees
    AND e.officeCode IN (
        SELECT officeCode 
        FROM employees 
        GROUP BY officeCode 
        HAVING COUNT(employeeNumber) > 3
    );


46. Calculate the total revenue per country (join customers → orders → orderdetails). Show only countries with revenue > 200,000. Sort descending.

SELECT  c.country, SUM(od.quantityOrdered * od.priceEach) AS totalRevenue FROM customers c JOIN  orders o ON c.customerNumber = o.customerNumber JOIN orderdetails od ON o.orderNumber = od.orderNumber GROUP BY  c.country HAVING  SUM(od.quantityOrdered * od.priceEach) > 200000 ORDER BY totalRevenue DESC;

47. Show the sales performance of each office: number of orders, total revenue, and average order value

SELECT  off.officeCode,off.city,COUNT(DISTINCT o.orderNumber) AS totalOrders, SUM(od.quantityOrdered * od.priceEach) AS totalRevenue, SUM(od.quantityOrdered * od.priceEach) / COUNT(DISTINCT o.orderNumber) AS averageOrderValue FROM offices off JOIN 
employees e ON off.officeCode = e.officeCode JOIN  customers c ON e.employeeNumber = c.salesRepEmployeeNumber JOIN  orders o ON c.customerNumber = o.customerNumber JOIN  orderdetails od ON o.orderNumber = od.orderNumber GROUP BY  off.officeCode,  off.city
ORDER BY  totalRevenue DESC;

48. Find products that have been ordered by customers from more than 3 different countries.

select p.productcode,p.productname,count(c.country) as countries from products p join orderdetails od on p.productcode = od.productcode join orders o on od.ordernumber = o. ordernumber join customers c on o.customernumber = c.customernumber group by p.productcode,p.productname HAVING  COUNT(DISTINCT c.country) > 3;

49. List sales reps whose customers have an average credit limit higher than the company average.

select  e.employeenumber,e.firstname,e.lastname,avg(c.creditlimit) as avereagecreditlimit from employees e join customers c on e. employeenumber = c.salesrepemployeenumber group by e.employeenumber,  e.firstName,  e.lastName HAVING  AVG(c.creditLimit) > (SELECT AVG(creditLimit) FROM customers);

50. For each product line, show: Total products, Total quantity sold, Total revenue, Average price per unit sold. Filter lines with revenue > 500,000. Sort by revenue descending.

SELECT  pl.productLine,COUNT(DISTINCT p.productCode) AS totalProducts,SUM(od.quantityOrdered) AS totalQuantitySold,SUM(od.quantityOrdered * od.priceEach) AS totalRevenue, SUM(od.quantityOrdered * od.priceEach) / SUM(od.quantityOrdered)AS avgPricePerUnitSold FROM  productlines pl JOIN  products p ON pl.productLine = p.productLine JOIN orderdetails od ON p.productCode = od.productCode GROUP BY pl.productLine HAVING SUM(od.quantityOrdered * od.priceEach) > 500000 ORDER BY totalRevenue DESC;



