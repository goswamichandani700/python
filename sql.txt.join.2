1. List all customers along with their sales representative's first name and last name (equi join on `salesRepEmployeeNumber`).

SELECT c.customerName, e.firstName,  e.lastName FROM customers c,employees e WHERE c.salesRepEmployeeNumber = e.employeeNumber;


2. Find all orders placed by customers from 'USA'. Show `orderNumber`, `customerName`, and `orderDate`.

SELECT o.orderNumber, c.customerName, o.orderDate FROM orders o, customers c WHERE o.customerNumber = c.customerNumber AND c.country = 'USA'ORDER BY  o.orderNumber;

3. Display product details (`productName`, `productLine`) along with the product line's text description.

Select p.productName, p.productLine,  pl.textDescription FROM  products p, productlines pl WHERE  p.productLine = pl.productLine;

 4. Show all employees and their office city and country.

SELECT e.firstName, e.lastName, f.city, f.country FROM employees e, offices f WHERE  e.officeCode = f.officeCode;


5. List all payments with the corresponding customer name and amount.

SELECT c.customerName, p.checkNumber,p.amount FROM customers c, payments p WHERE c.customerNumber = p.customerNumber;

6. Find all order details (`orderNumber`, `productCode`, `quantityOrdered`) with the product name.

select d.ordernumber, d.productCode, d.quantityordered,p.productname from orderdetails d, products p where d.productcode = p.productcode

7. Show customers from 'France' and their sales rep's job title.

SELECT  c.customerName, c.country, e.jobTitle  FROM customers c,  employees e WHERE c.salesRepEmployeeNumber = e.employeeNumber AND c.country = 'France';

8. Display all products in the 'Classic Cars' product line with their buy price and MSRP.

   SELECT p.productName,p.productLine, p.buyPrice, p.MSRP FROM products p, productlines pl WHERE p.productLine = pl.productLine 
    AND p.productLine = 'Classic Cars';

9. List employees who report to 'Diane Murphy' (use equi join on `reportsTo`).  


SELECT employees.firstName, employees.lastName, employees.jobTitle FROM employees, employees managers WHERE employees.reportsTo = managers.employeeNumber AND managers.firstName = 'Diane' AND managers.lastName = 'Murphy';

10. Show all orders that are 'Shipped' along with the customer name.

SELECT 
    orders.orderNumber, 
    orders.status, 
    orders.shippedDate, 
    customers.customerName
FROM 
    orders, 
    customers
WHERE 
    orders.customerNumber = customers.customerNumber 
    AND orders.status = 'Shipped';
    
11. List all customers and their sales representative's name (use LEFT JOIN). Include customers who have no sales rep.
SELECT  c.customerNumber, c.customerName, e.firstName AS repFirstName, e.lastName AS repLastName FROM customers c 
LEFT JOIN employees e ON c.salesRepEmployeeNumber = e.employeeNumber;

SELECT  e.employeeNumber, e.lastName, e.firstName, c.customerNumber, c.customerName FROM employees e LEFT JOIN customers c ON e.employeeNumber = c.salesRepEmployeeNumber

13. List all products and how many times they have been ordered (use LEFT JOIN with `orderdetails`). 

SELECT p.productCode,  p.productName,  p.productLine,COUNT(od.orderNumber) AS timesOrdered FROM products p LEFT JOIN orderdetails od ON p.productCode = od.productCode GROUP BY p.productCode, p.productName, p.productLine;

14. Show all offices and the number of employees in each office (use LEFT JOIN).

SELECT  o.officeCode,  o.city,  o.country, e.employeeNumber, e.firstName, e.lastName FROM offices o LEFT JOIN employees e ON o.officeCode = e.officeCode;

15. Display all customers and their total payment amount (use LEFT JOIN with `payments`).

select c.customernumber,c.customername, p.amount from customers c left join payments p  on c.customernumber = p.customernumber


16. Use RIGHT JOIN to show all employees and any customers they represent.
SELECT  e.employeeNumber, e.lastName,  e.firstName,  e.officeCode,  c.customerNumber, c.customerName FROM customers c 
RIGHT JOIN employees e ON c.salesRepEmployeeNumber = e.employeeNumber;

17. Use LEFT JOIN to list all product lines and the products in them.

select p.productcode, p. productname, pl.productline from productlines pl left join products p on pl.productline = p. productline

18. Show all orders and the customer name, including orders without a matching customer (if any).

select o.ordernumber, o.customernumber, c.customername from orders o left join customers c on o.customernumber = c.customernumber 

19. Find the total number of orders per customer. Show `customerName` and order count.

SELECT  c.customerNumber,c.customerName, COUNT(o.orderNumber) AS totalOrders FROM customers c LEFT JOIN orders o ON c.customerNumber = o.customerNumber GROUP BY c.customerNumber, c.customerName;

20. Calculate total sales amount (sum of `priceEach * quantityOrdered`) per product line.

SELECT  p.productLine,SUM(od.priceEach * od.quantityOrdered) AS totalSalesAmount FROM orderdetails od LEFT JOIN products p ON od.productCode = p.productCode GROUP BY p.productLine;

21. Find the average credit limit of customers by country.
select country,avg(creditlimit) as averagecreditlimit from customers group by country order by creditlimit


22. Show the number of employees per office city.
SELECT o.city, COUNT(e.employeeNumber) AS numberOfEmployees FROM offices o LEFT JOIN employees e ON o.officeCode = e.officeCode
GROUP BY o.city ORDER BY numberOfEmployees 

23. Find the total payment amount received from each customer.
select c.customernumber, c. customername, p.amount from customers c left join payments p on c.customernumber = p.customernumber 

24. Count how many products are in each product line.
SELECT p.productCode,p.productName,pl.productLine FROM products p LEFT JOIN productlines pl ON p.productLine = pl.productLine;

25. Find the total quantity ordered for each product (top 5 by quantity).
SELECT  p.productCode,  p.productName,  SUM(od.quantityOrdered) AS totalQuantityOrdered FROM products p INNER JOIN orderdetails od ON p.productCode = od.productCode GROUP BY p.productCode, p.productName ORDER BY totalQuantityOrdered DESC LIMIT 5;

26. Find customers who have placed more than 5 orders.
SELECT c.customerNumber, c.customerName, COUNT(o.orderNumber) AS totalOrders FROM customers c INNER JOIN orders o ON c.customerNumber = o.customerNumber GROUP BY c.customerNumber, c.customerName HAVING COUNT(o.orderNumber) > 5 ORDER BY totalOrders DESC;

27. Show product lines where the average MSRP is greater than 100.

 SELECT  productLine,  AVG(MSRP) AS average_msrp FROM  products GROUP BY productLine HAVING  AVG(MSRP) > 100;

28. Find sales reps (employees) who have managed more than 10 customers.

SELECT e.employeeNumber,e.firstName, e.lastName, COUNT(c.customerNumber) AS customer_count FROM employees e INNER JOIN  customers c ON e.employeeNumber = c.salesRepEmployeeNumber GROUP BY e.employeeNumber, e.firstName, e.lastName HAVING COUNT(c.customerNumber) > 10;


29. List countries where the total payment amount exceeds 500,000.
SELECT  c.country,  SUM(p.amount) AS total_payment  FROM  payments p JOIN customers c ON p.customernumber = c.customernumber
GROUP BY  c.country HAVING  total_payment > 500000 ORDER BY total_payment DESC LIMIT 0, 25;


30. Find offices that have more than 5 employees.

SELECT o.officeCode,  o.city,  COUNT(e.employeeNumber) AS total_employees FROM  offices o JOIN employees e ON o.officeCode = e.officeCode GROUP BY o.officeCode, o.city  HAVING   COUNT(e.employeeNumber) > 5;

31. List customers sorted by their total payment amount (highest first).

select c.customernumber, c.customername, sum(p.amount) as total_payment from customers c join payments p on c.customernumber = p.customernumber group by c.customernumber, c.customername order by total_payment desc limit 0,25

