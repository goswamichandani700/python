create table student (
    id int PRIMARY KEY AUTO_INCREMENT, 
    fullname VARCHAR(128) NOT NULL, 
    gender VARCHAR(6) NOT NULL, 
    dob date not null, 
    email varchar(128) unique not null, 
    mobile varchar(10) unique not null,) 
------------------------------------------------------
create table employee(empid int primary key AUTO_INCREMENT,
   empname varchar(128) NOT NULL,
   salary FLOAT check (salary > 10000),
   department VARCHAR(50), 
   joining_date DATE)  
------------------------------------------------------------
create a table named product with:

create table product(
      productid INT PRIMARY KEY AUTO_INCREMENT,
      productname VARCHAR(128) NOT NULL,
      price float check (price > 0),
      stock INT,
      status VARCHAR(50) default 'Available')
-------------------------------------------------------------------
create a table named 'course' with

create table course(
   courseid INT PRIMARY KEY AUTO_INCREMENT,
   coursename VARCHAR(128) NOT NULL,
   fees FLOAT,
   duration varchar(50)
)

19. Increase the height of all teachers by 1 foot.
update teacher set height=height+1

20. Increase the weight of all teachers by 5 kg.
update teacher set weight = weight+5

21. Change the weight of Rahul Sharma to 100 kg.
update teacher set weight=100 where fullname='rahul sharma'

22. Change the gender of teacher id 5 to female.
update teacher set fullname='monika sharma', gender='female' where id=5

23. Update the email address of Vikram Singh.
UPDATE teacher SET email = 'visingh@gmail.com' WHERE email = 'vivaan2@gmail.com';

24. Increase the height of all female teachers by 0.5 feet.
UPDATE teacher 
SET height = height + 0.5 
WHERE gender = 'Female'

25. Set the photo field to "default.jpg" for all teachers.
UPDATE teacher 
SET photo = 'default.jpg' 
WHERE photo = 'photo.jpg'

26. Change the mobile number of teacher id 25.
update teacher set mobile=12345678 where id=25

-------------------------------------------------

27. Display all teacher records.
select * from teacher 


28. Display only fullname and email.
select fullname, email from teacher 


29. Display fullname, mobile, and weight.
select fullname, mobile, weight from teacher


30. Display all teachers sorted by fullname.

select * from teacher order by fullname asc 
OR 
select * from teacher order by fullname 



31. Display all teachers sorted by weight.
select * from teacher order by weight



32. Display only first 10 teacher records.

select * from teacher limit 0,10


33. Display the first 5 teachers sorted by date of birth.
select * from teacher order by dob asc limit 0,5

