## Part 6: WHERE Clause Exercises

34. Display all male teachers.
select id,fullname,email,gender from teacher where gender='male'

35. Display all female teachers.
select id,fullname,email,gender from teacher where gender='female'

36. Display teachers whose weight is above 80 kg.
select id,fullname,email,gender,weight from teacher where weight>80

37. Display teachers whose weight is below 60 kg.
select id,fullname,email,gender,weight from teacher where weight<60

38. Display teachers whose height is greater than 5.8 feet.
select id,fullname,email,gender,height from teacher where height>5.8

39. Display teachers born after 2000.
select id,fullname,dob from teacher where dob>'2000-12-31' order by dob 

40. Display teachers born before 2001.
select id,fullname,dob from teacher where dob<'2001-12-31' order by dob 


41. Display teachers whose name is Rahul Sharma.
SELECT * 
FROM teacher 
WHERE fullname = 'aditya verma'


42. Display teachers whose email contains "gmail.com".
SELECT * 
FROM teacher 
WHERE email LIKE '%gmail.com%'

43. Display teachers whose weight is between 70 and 80.
SELECT * 
FROM teacher 
WHERE weight BETWEEN 70 AND 80

44. Display teachers whose height is between 5.4 and 5.8.
SELECT * 
FROM teacher 
WHERE height BETWEEN 7.1 AND 8.8;
